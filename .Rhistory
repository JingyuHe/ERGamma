dalpha = function(x)
{
prod(beta^x/gamma(x)*y^(x-1)*exp(-beta*y))
}
dalpha2 = function(x)
{
1/gamma(x)^b_prime * beta_y^x
}
x = seq(2.5,3.5,0.01)
Z = integrate(dalpha2,lower = 2,upper = 4)
